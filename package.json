{
  "name": "drop-scout",
  "version": "0.1.0",
  "description": "CLI benchmark for CS2 digital-goods market timing from human trade data.",
  "type": "module",
  "bin": {
    "dropscout": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example",
    "data/raw/.gitkeep",
    "data/normalized/.gitkeep",
    "reports/.gitkeep"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package:smoke": "npm run build && node ./dist/cli.js --version",
    "fetch": "tsx src/cli.ts fetch",
    "normalize": "tsx src/cli.ts normalize",
    "benchmark": "tsx src/cli.ts benchmark",
    "agent:benchmark": "tsx src/cli.ts agent-benchmark",
    "agent:matrix": "tsx src/cli.ts agent-matrix",
    "report": "tsx src/cli.ts report",
    "web:export": "tsx src/cli.ts web-export",
    "web:dev": "npm --prefix apps/web run dev --",
    "web:build": "npm --prefix apps/web run build",
    "web:typecheck": "npm --prefix apps/web run typecheck"
  },
  "keywords": [
    "cs2",
    "benchmark",
    "market-data",
    "agentic-commerce"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/google": "^3.0.75",
    "ai": "^6.0.185",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.6"
  }
}
